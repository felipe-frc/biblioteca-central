@model IEnumerable<Biblioteca.Domain.Entities.Livro>
@using System.Linq

@{
    ViewData["Title"] = "Livros";

    var livros = Model?.ToList() ?? new List<Biblioteca.Domain.Entities.Livro>();
    var totalLivros = ViewBag.TotalLivros is int tl ? tl : livros.Count;
    var disponiveis = ViewBag.TotalDisponiveis is int td ? td : livros.Count(l => l.Disponivel);
    var publicacaoMaisRecente = ViewBag.PublicacaoMaisRecente?.ToString() ?? "-";

    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var hasPreviousPage = ViewBag.HasPreviousPage is bool hp && hp;
    var hasNextPage = ViewBag.HasNextPage is bool hn && hn;
}

<section class="crud-page crud-page-livros">
    <div class="container">
        @if (TempData["Erro"] is not null)
        {
            <div class="crud-alert crud-alert-danger">@TempData["Erro"]</div>
        }

        @if (TempData["Sucesso"] is not null)
        {
            <div class="crud-alert crud-alert-success">@TempData["Sucesso"]</div>
        }

        <div class="crud-header">
            <h1 class="crud-title">Livros</h1>
            <span class="crud-line"></span>
            <a class="crud-primary-btn" asp-controller="Livros" asp-action="Create">+ Novo Livro</a>
        </div>

        @if (!livros.Any())
        {
            <div class="crud-empty-state">
                <h3>Nenhum livro cadastrado.</h3>
                <p>Cadastre o primeiro livro para começar a organizar sua biblioteca.</p>
            </div>
        }
        else
        {
            <div class="crud-table-card">
                <div class="crud-table-wrap">
                    <table class="crud-table">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Título</th>
                                <th>Autor</th>
                                <th>Editora</th>
                                <th>Edição</th>
                                <th>Publicação</th>
                                <th>Páginas</th>
                                <th>Disponível</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var livro in livros)
                            {
                                <tr>
                                    <td class="crud-id" data-label="Id">@livro.Id</td>
                                    <td class="crud-strong" data-label="Título">@livro.Titulo</td>
                                    <td data-label="Autor">@livro.Autor</td>
                                    <td data-label="Editora">@livro.Editora</td>
                                    <td data-label="Edição">@livro.Edicao</td>
                                    <td data-label="Publicação">@livro.DataPublicacao.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Páginas">@livro.NumeroPaginas</td>
                                    <td data-label="Disponível">
                                        <span class="crud-pill @(livro.Disponivel ? "crud-pill-success" : "crud-pill-danger")">
                                            @(livro.Disponivel ? "Sim" : "Não")
                                        </span>
                                    </td>
                                    <td class="crud-actions-cell" data-label="Ações">
                                        <div class="crud-actions">
                                            <a class="crud-action-btn crud-action-btn-edit"
                                               asp-controller="Livros"
                                               asp-action="Edit"
                                               asp-route-id="@livro.Id">
                                                Editar
                                            </a>

                                            <a class="crud-action-btn crud-action-btn-delete"
                                               asp-controller="Livros"
                                               asp-action="Delete"
                                               asp-route-id="@livro.Id">
                                                Excluir
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (totalPages > 0)
            {
                <nav class="crud-pagination" aria-label="Paginação">
                    @if (hasPreviousPage)
                    {
                        <a class="crud-pagination-link" asp-action="Index" asp-route-page="@(currentPage - 1)">Anterior</a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Anterior</span>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <span class="crud-pagination-link is-active">@i</span>
                        }
                        else
                        {
                            <a class="crud-pagination-link" asp-action="Index" asp-route-page="@i">@i</a>
                        }
                    }

                    @if (hasNextPage)
                    {
                        <a class="crud-pagination-link" asp-action="Index" asp-route-page="@(currentPage + 1)">Próxima</a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Próxima</span>
                    }
                </nav>
            }

            <div class="row g-4 crud-stats-row">
                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Total de Livros</span>
                        <strong class="crud-stat-value">@totalLivros</strong>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Disponíveis</span>
                        <strong class="crud-stat-value">@disponiveis</strong>
                    </div>
                </div>

                <div class="col-lg-4 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Publicação Mais Recente</span>
                        <strong class="crud-stat-value">@publicacaoMaisRecente</strong>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
