@model Biblioteca.Web.ViewModels.LivroFormViewModel

@{
    ViewData["Title"] = "Novo Livro";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";
}

<section class="crud-page crud-form-page">
    <div class="container">
        <div class="crud-header crud-header-form">
            <div>
                <h1 class="crud-title">Novo Livro</h1>
                <span class="crud-line"></span>
            </div>
        </div>

        <div class="crud-form-card">
            <form asp-action="Create" method="post" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="crud-alert crud-alert-danger crud-validation-summary"></div>

                <p class="mb-4 fw-semibold text-danger">* Campo obrigatório</p>

                <div class="crud-form-grid">
                    <div class="crud-form-group">
                        <label asp-for="Titulo" class="crud-form-label">Título <span class="text-danger">*</span></label>
                        <input asp-for="Titulo" class="crud-form-control" placeholder="Digite o título do livro" />
                        <span asp-validation-for="Titulo" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group">
                        <label asp-for="Autor" class="crud-form-label">Autor <span class="text-danger">*</span></label>
                        <input asp-for="Autor" class="crud-form-control" placeholder="Digite o nome do autor" />
                        <span asp-validation-for="Autor" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group">
                        <label asp-for="Editora" class="crud-form-label">Editora <span class="text-danger">*</span></label>
                        <input asp-for="Editora" class="crud-form-control" placeholder="Digite o nome da editora" />
                        <span asp-validation-for="Editora" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group crud-form-group-small">
                        <label asp-for="Edicao" class="crud-form-label">Edição <span class="text-danger">*</span></label>
                        <input asp-for="Edicao" class="crud-form-control" placeholder="Ex: 1ª edição" />
                        <span asp-validation-for="Edicao" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group crud-form-group-small">
                        <label asp-for="DataPublicacao" class="crud-form-label">Data de Publicação <span class="text-danger">*</span></label>
                        <input asp-for="DataPublicacao" class="crud-form-control" type="date" />
                        <span asp-validation-for="DataPublicacao" class="crud-field-validation"></span>
                    </div>

                    <div class="crud-form-group crud-form-group-small">
                        <label asp-for="NumeroPaginas" class="crud-form-label">Número de Páginas <span class="text-danger">*</span></label>
                        <input asp-for="NumeroPaginas" class="crud-form-control" type="number" min="1" placeholder="Ex: 320" />
                        <span asp-validation-for="NumeroPaginas" class="crud-field-validation"></span>
                    </div>
                </div>

                <div class="crud-form-actions">
                    <button type="submit" class="crud-primary-btn">Salvar Livro</button>
                    <a asp-action="Index" class="crud-secondary-btn">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
