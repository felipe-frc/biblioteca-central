<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <!-- Meta Tags Essenciais -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
    <meta name="description" content="Biblioteca Áurea - Sistema de Gerenciamento" />
    <meta name="theme-color" content="#183d60" />

    <!-- Título Dinâmico -->
    <title>@ViewData["Title"] - Biblioteca Áurea</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/images/logo-biblioteca.png" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Preconnect para Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body class="inner-body">
    @{
        var controllerAtual = ViewContext.RouteData.Values["controller"]?.ToString();
        var usuarioLogado = User.Identity?.IsAuthenticated == true;
    }

    <!-- ============================================
         HEADER / NAVBAR INTERNO
         ============================================ -->
    <header>
        <nav class="navbar navbar-expand-lg inner-navbar fixed-top">
            <div class="container-fluid inner-navbar-container">
                <a class="navbar-brand inner-brand"
                   href="@Url.Action("Index", "Home")"
                   aria-label="Biblioteca Áurea - Voltar para Home">
                    <img src="~/images/logo-biblioteca-completa.png"
                         alt="Logo Biblioteca Áurea"
                         class="inner-logo"
                         loading="lazy" />
                </a>

                <button class="navbar-toggler inner-navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#innerMenu"
                        aria-controls="innerMenu"
                        aria-expanded="false"
                        aria-label="Abrir menu de navegação">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="innerMenu">
                    <ul class="navbar-nav ms-auto inner-nav-list">
                        @if (usuarioLogado)
                        {
                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Dashboard" ? "active" : "")"
                                   href="@Url.Action("Index", "Dashboard")"
                                   aria-current="@(controllerAtual == "Dashboard" ? "page" : "false")">
                                    Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Livros" ? "active" : "")"
                                   href="@Url.Action("Index", "Livros")"
                                   aria-current="@(controllerAtual == "Livros" ? "page" : "false")">
                                    Livros
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Usuarios" ? "active" : "")"
                                   href="@Url.Action("Index", "Usuarios")"
                                   aria-current="@(controllerAtual == "Usuarios" ? "page" : "false")">
                                    Usuários
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Emprestimos" ? "active" : "")"
                                   href="@Url.Action("Index", "Emprestimos")"
                                   aria-current="@(controllerAtual == "Emprestimos" ? "page" : "false")">
                                    Empréstimos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Catalogo" ? "active" : "")"
                                   href="@Url.Action("Index", "Catalogo")"
                                   aria-current="@(controllerAtual == "Catalogo" ? "page" : "false")">
                                    Catálogo
                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Admin"
                                      asp-action="Logout"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="nav-link inner-nav-link border-0 bg-transparent">
                                        Sair
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Home" ? "active" : "")"
                                   href="@Url.Action("Index", "Home")"
                                   aria-current="@(controllerAtual == "Home" ? "page" : "false")">
                                    Home
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Catalogo" ? "active" : "")"
                                   href="@Url.Action("Index", "Catalogo")"
                                   aria-current="@(controllerAtual == "Catalogo" ? "page" : "false")">
                                    Catálogo
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link inner-nav-link @(controllerAtual == "Admin" ? "active" : "")"
                                   href="@Url.Action("Login", "Admin")"
                                   aria-current="@(controllerAtual == "Admin" ? "page" : "false")">
                                    Login Administrativo
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ============================================
         MAIN CONTENT
         ============================================ -->
    <main class="inner-main">
        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <!-- ============================================
         FOOTER INTERNO
         ============================================ -->
    <footer class="inner-footer">
        <div class="container-fluid text-center">
            <p class="mb-0">&copy; 2026 Biblioteca Áurea. Todos os direitos reservados.</p>
        </div>
    </footer>

    <!-- ============================================
         SCRIPTS
         ============================================ -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <style>
        .toast-alert-container {
            position: fixed;
            top: 100px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-width: 420px;
            width: calc(100% - 48px);
            pointer-events: none;
        }

        .toast-alert-container .crud-alert {
            margin: 0;
            box-shadow: 0 14px 35px rgba(0, 0, 0, 0.14);
            border-radius: 14px;
            animation: toastSlideIn 0.35s ease forwards;
            pointer-events: auto;
        }

        .toast-alert-container .crud-alert.toast-alert-hide {
            animation: toastSlideOut 0.35s ease forwards;
        }

        @@keyframes toastSlideIn {
            from {
                opacity: 0;
                transform: translateX(24px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes toastSlideOut {
            from {
                opacity: 1;
                transform: translateX(0);
            }

            to {
                opacity: 0;
                transform: translateX(24px);
            }
        }

        @@media (max-width: 576px) {
            .toast-alert-container {
                top: 90px;
                right: 16px;
                left: 16px;
                width: auto;
                max-width: none;
            }
        }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const alerts = document.querySelectorAll(".crud-alert:not(.crud-validation-summary)");

            if (!alerts.length) {
                return;
            }

            const container = document.createElement("div");
            container.className = "toast-alert-container";
            container.setAttribute("aria-live", "polite");
            container.setAttribute("aria-atomic", "true");
            document.body.appendChild(container);

            alerts.forEach(function (alert) {
                container.appendChild(alert);

                setTimeout(function () {
                    alert.classList.add("toast-alert-hide");

                    setTimeout(function () {
                        alert.remove();

                        if (!container.children.length) {
                            container.remove();
                        }
                    }, 350);
                }, 4000);
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>