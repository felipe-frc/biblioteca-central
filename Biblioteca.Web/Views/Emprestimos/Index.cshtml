@model IEnumerable<Biblioteca.Domain.Entities.Emprestimo>
@using System.Linq
@using Biblioteca.Domain.Enums

@{
    ViewData["Title"] = "Empréstimos";
    Layout = "~/Views/Shared/_LayoutInner.cshtml";

    var emprestimos = Model?.ToList() ?? new List<Biblioteca.Domain.Entities.Emprestimo>();
    var hoje = DateTime.Today;

    foreach (var emprestimo in emprestimos)
    {
        emprestimo.AtualizarStatus(hoje);
    }

    var totalEmprestimos = ViewBag.TotalEmprestimos is int te ? te : emprestimos.Count;

    var ativos = ViewBag.Ativos is int at
        ? at
        : emprestimos.Count(e => e.DataDevolucao is null && !e.EstaAtrasado(hoje));

    var atrasados = ViewBag.Atrasados is int atr
        ? atr
        : emprestimos.Count(e => e.DataDevolucao is null && e.EstaAtrasado(hoje));

    var devolvidos = ViewBag.Devolvidos is int de
        ? de
        : emprestimos.Count(e => e.DataDevolucao is not null);

    var filtroStatus = ViewBag.FiltroStatus?.ToString() ?? "todos";

    var currentPage = ViewBag.CurrentPage is int cp ? cp : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    var hasPreviousPage = ViewBag.HasPreviousPage is bool hp && hp;
    var hasNextPage = ViewBag.HasNextPage is bool hn && hn;
}

<section class="crud-page crud-page-emprestimos">
    <div class="container">
        @if (TempData["Erro"] is not null)
        {
            <div class="crud-alert crud-alert-danger">@TempData["Erro"]</div>
        }

        @if (TempData["Sucesso"] is not null)
        {
            <div class="crud-alert crud-alert-success">@TempData["Sucesso"]</div>
        }

        <div class="crud-header">
            <h1 class="crud-title">Empréstimos</h1>
            <span class="crud-line"></span>
            <a asp-controller="Emprestimos" asp-action="Create" class="crud-primary-btn">+ Novo Empréstimo</a>
        </div>

        <div class="crud-form-card mb-4">
            <form method="get" action="/Emprestimos">
                <div class="crud-form-grid">
                    <div class="crud-form-group crud-form-group-small">
                        <label for="filtroStatus" class="crud-form-label">Status do Empréstimo</label>

                        <select id="filtroStatus"
                                name="filtroStatus"
                                class="crud-form-control crud-form-select">
                            @if (filtroStatus == "todos")
                            {
                                <option value="todos" selected>Todos</option>
                            }
                            else
                            {
                                <option value="todos">Todos</option>
                            }

                            @if (filtroStatus == "ativos")
                            {
                                <option value="ativos" selected>Ativos</option>
                            }
                            else
                            {
                                <option value="ativos">Ativos</option>
                            }

                            @if (filtroStatus == "atrasados")
                            {
                                <option value="atrasados" selected>Atrasados</option>
                            }
                            else
                            {
                                <option value="atrasados">Atrasados</option>
                            }

                            @if (filtroStatus == "devolvidos")
                            {
                                <option value="devolvidos" selected>Devolvidos</option>
                            }
                            else
                            {
                                <option value="devolvidos">Devolvidos</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="crud-form-actions">
                    <button type="submit" class="crud-primary-btn">Filtrar</button>
                    <a href="/Emprestimos" class="crud-secondary-btn">Limpar Filtros</a>
                </div>
            </form>
        </div>

        @if (!emprestimos.Any())
        {
            <div class="crud-empty-state">
                <h3>Nenhum empréstimo encontrado.</h3>

                @if (filtroStatus != "todos")
                {
                    <p>Nenhum resultado corresponde ao status selecionado.</p>
                    <a href="/Emprestimos" class="crud-secondary-btn mt-3">Limpar Filtros</a>
                }
                else
                {
                    <p>Registre o primeiro empréstimo para acompanhar as devoluções.</p>
                }
            </div>
        }
        else
        {
            <div class="crud-table-card">
                <div class="crud-table-wrap">
                    <table class="crud-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Livro</th>
                                <th>Usuário</th>
                                <th>Retirada</th>
                                <th>Previsão</th>
                                <th>Devolução</th>
                                <th>Status</th>
                                <th>Atraso</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in emprestimos)
                            {
                                var estaAtrasado = e.DataDevolucao is null && e.EstaAtrasado(hoje);
                                var diasAtraso = estaAtrasado
                                ? (hoje - e.DataPrevistaDevolucao.Date).Days
                                : 0;

                                var statusTexto = e.DataDevolucao is not null
                                ? "Devolvido"
                                : estaAtrasado
                                ? "Atrasado"
                                : "Ativo";

                                var statusClasse = e.DataDevolucao is not null
                                ? "crud-pill-success"
                                : estaAtrasado
                                ? "crud-pill-danger"
                                : "crud-pill-warning";

                                <tr>
                                    <td class="crud-id" data-label="ID">@e.Id</td>
                                    <td class="crud-strong" data-label="Livro">@e.Livro?.Titulo</td>
                                    <td data-label="Usuário">@e.Usuario?.Nome</td>
                                    <td data-label="Retirada">@e.DataEmprestimo.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Previsão">@e.DataPrevistaDevolucao.ToString("dd/MM/yyyy")</td>
                                    <td data-label="Devolução">
                                        @(e.DataDevolucao is null ? "-" : e.DataDevolucao.Value.ToString("dd/MM/yyyy"))
                                    </td>
                                    <td data-label="Status">
                                        <span class="crud-pill @statusClasse">
                                            @statusTexto
                                        </span>
                                    </td>
                                    <td data-label="Atraso">
                                        @if (estaAtrasado)
                                        {
                                            <span class="text-danger fw-semibold">
                                                @diasAtraso @(diasAtraso == 1 ? "dia" : "dias")
                                            </span>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td class="crud-actions-cell" data-label="Ações">
                                        <div class="crud-actions">
                                            @if (e.DataDevolucao is null)
                                            {
                                                <form asp-controller="Emprestimos"
                                                      asp-action="Devolver"
                                                      asp-route-id="@e.Id"
                                                      method="post"
                                                      class="crud-inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="crud-action-btn crud-action-btn-edit">
                                                        <span class="crud-action-icon" aria-hidden="true">
                                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                                <path d="M21 12a9 9 0 1 1-3.2-6.9" />
                                                                <path d="M21 3v6h-6" />
                                                            </svg>
                                                        </span>
                                                        Devolver
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="crud-action-dash">—</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (totalPages > 0)
            {
                <nav class="crud-pagination" aria-label="Paginação">
                    @if (hasPreviousPage)
                    {
                        <a class="crud-pagination-link"
                           asp-controller="Emprestimos"
                           asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-filtroStatus="@filtroStatus">
                            Anterior
                        </a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Anterior</span>
                    }

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <span class="crud-pagination-link is-active">@i</span>
                        }
                        else
                        {
                            <a class="crud-pagination-link"
                               asp-controller="Emprestimos"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-filtroStatus="@filtroStatus">
                                @i
                            </a>
                        }
                    }

                    @if (hasNextPage)
                    {
                        <a class="crud-pagination-link"
                           asp-controller="Emprestimos"
                           asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-filtroStatus="@filtroStatus">
                            Próxima
                        </a>
                    }
                    else
                    {
                        <span class="crud-pagination-link is-disabled">Próxima</span>
                    }
                </nav>
            }

            <div class="row g-4 crud-stats-row">
                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Empréstimos Encontrados</span>
                        <strong class="crud-stat-value">@totalEmprestimos</strong>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Ativos</span>
                        <strong class="crud-stat-value">@ativos</strong>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-gold">
                        <span class="crud-stat-label">Atrasados</span>
                        <strong class="crud-stat-value">@atrasados</strong>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6">
                    <div class="crud-stat-card crud-stat-blue">
                        <span class="crud-stat-label">Devolvidos</span>
                        <strong class="crud-stat-value">@devolvidos</strong>
                    </div>
                </div>
            </div>
        }
    </div>
</section>